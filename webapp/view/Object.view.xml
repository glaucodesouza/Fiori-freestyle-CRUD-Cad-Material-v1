<mvc:View
	controllerName="cadmatv1.controller.Object"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:l="sap.ui.layout"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:semantic="sap.f.semantic">

	<semantic:SemanticPage
		id="objectPage"
		showFooter="true"
		headerPinnable="false"
		toggleHeaderOnTitleClick="false"
		busy="{objectView>/busy}"
		busyIndicatorDelay="{objectView>/delay}">

		<semantic:titleHeading>
			<Title
				text="{Bukrs}"
				level="H2"/>
		</semantic:titleHeading>

		<semantic:headerContent>
			<ObjectNumber
				unit="{Matnr}"
			/>
		</semantic:headerContent>

		<l:VerticalLayout width="100%">
				<f:SimpleForm
					editable="true"
					layout="ResponsiveGridLayout"
					labelSpanXL="3"
					labelSpanL="3"
					labelSpanM="3"
					labelSpanS="12"
					adjustLabelSpan="false"
					emptySpanXL="4"
					emptySpanL="4"
					emptySpanM="4"
					emptySpanS="0"
					columnsXL="1"
					columnsL="1"
					columnsM="1"
					singleContainerFullSize="false"
					>
					
                    <Label text="Empresa" />
					<Text 
						text="{Bukrs}" 
                    />

					<Label text="Material" />
					<Input  
						value="{Matnr}" 
                    />

					<Label text="Descrição" />
					<Input  
						value="{Maktx}" 
                    />	
					
					<Label text="Quantidade" />
					<Input  
						value="{Menge}"
						showValueHelp="true"
						valueHelpRequest=".onValueHelpRequest"
                    />

					<Label text="UM" />
					<Input  
						value="{Meins}"
						showValueHelp="true"
						valueHelpRequest=".onValueHelpRequest"
                    />
				</f:SimpleForm>					

		<List
			growing="true"
			growingScrollToLoad="true"
			growingThreshold="20"
			headerText="{i18n>vendaListCliente}"
			class="sapUiResponsiveMargin"
			width="auto"
			items="{
			path : 'vendas',
			parameters:{
				expand: 'cliente'
			},
			sorter: {
                path: 'Bukrs',
                descending: true
			}
		}">
		<items>
		<ObjectListItem
			title="{Descricao}"
			number="{ValorLiquido}"
			numberState="{=	${ValorLiquido} > 500 ? 'Error' : 'Success' }"
			>

			<attributes>
			<ObjectAttribute text="{IDVenda}" />
			<ObjectAttribute 
			text="{DataCriacao}" />
			<ObjectAttribute text="{cliente/Email}" />
			</attributes>
		</ObjectListItem>
		</items>
	</List>


	</l:VerticalLayout>

	<!-- Custom Footer Content-->
	<semantic:footerCustomActions>
		<Button type="Accept" text="Alterar" press="onPressAlterar" />
		<Button type="Accept" text="Gravar" press="onGravar" />
		<Button type="Reject" text="Cancelar" press="onCancelar" />
	</semantic:footerCustomActions>	

	</semantic:SemanticPage>

</mvc:View>